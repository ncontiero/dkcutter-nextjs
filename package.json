{
  "name": "dkcutter-nextjs",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "bun@1.3.14",
  "description": "DKCutter Next.js is a robust template for quickly scaffolding production-ready Next.js applications with modern tooling.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "bun --bun tsc --noEmit",
    "generate": "bun --bun dkcutter .",
    "lint": "bun --bun eslint . -c eslint.config.ts",
    "lint:fix": "bun run lint --fix",
    "check": "bun run lint && bun run typecheck",
    "test": "bun --bun vitest run",
    "test:strict": "GET_WARNINGS=true bun run test",
    "commitlint": "commitlint --edit",
    "pre-commit": "lint-staged -c ./package.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@ncontiero/eslint-config": "8.2.1",
    "@types/bun": "1.3.14",
    "@types/prompts": "^2.4.9",
    "colorette": "^2.0.20",
    "dkcutter": "6.0.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prompts": "^2.4.2",
    "tinyexec": "^1.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*": "bun run lint:fix"
  }
}
