{
  "name": "dkcutter-nextjs",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.0",
  "description": "DKCutter NextJs is a framework for quickly starting Next.Js projects.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "dkcutter .",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "check": "pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:strict": "GET_WARNINGS=true pnpm test",
    "commitlint": "commitlint --edit",
    "pre-commit": "lint-staged -c ./package.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@ncontiero/eslint-config": "8.2.1",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "colorette": "^2.0.20",
    "dkcutter": "6.0.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prompts": "^2.4.2",
    "tinyexec": "^1.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  }
}
