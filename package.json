{
  "name": "dkcutter-nextjs",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@11.4.0",
  "description": "DKCutter NextJs is a framework for quickly starting Next.Js projects.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "dkcutter .",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "check": "pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:strict": "GET_WARNINGS=true pnpm test",
    "commitlint": "commitlint --edit",
    "pre-commit": "lint-staged -c ./package.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@clerk/nextjs": "^7.4.2",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@ncontiero/eslint-config": "8.2.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@trigger.dev/sdk": "4.4.6",
    "@types/node": "^25.9.1",
    "@types/prompts": "^2.4.9",
    "@types/react": "19.2.15",
    "better-auth": "1.6.11",
    "colorette": "^2.0.20",
    "dkcutter": "6.0.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "next": "16.2.6",
    "prompts": "^2.4.2",
    "react": "19.2.6",
    "tailwindcss": "4.3.0",
    "tinyexec": "^1.2.3",
    "tsx": "^4.22.3",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  }
}
