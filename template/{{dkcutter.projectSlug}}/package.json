{
  "name": "{{dkcutter.projectSlug}}",
  "type": "module",
  "version": "{{dkcutter.projectVersion}}",
  "private": true,
  "packageManager": "",
  "description": "{{dkcutter.description}}",
  "author": "{{dkcutter.authorName}}",
  "license": "MIT",
  "scripts": {
    "dev": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next dev",
    "build": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next build",
    "start": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "{{ dkcutter._pkgRun }} lint && {{ dkcutter._pkgRun }} typecheck"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.12",
    "@clerk/nextjs": "^7.4.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@trigger.dev/sdk": "4.4.6",
    "better-auth": "1.6.12",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@ncontiero/eslint-config": "8.2.1",
    "@tailwindcss/postcss": "4.3.0",
    "@trigger.dev/build": "4.4.6",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^10.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.15",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "trigger.dev": "4.4.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*": "{{ dkcutter._pkgRun }} lint:fix"
  }
}
