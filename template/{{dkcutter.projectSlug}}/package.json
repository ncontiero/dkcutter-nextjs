{
  "name": "{{dkcutter.projectSlug}}",
  "type": "module",
  "version": "{{dkcutter.projectVersion}}",
  "private": true,
  "packageManager": "",
  "description": "{{dkcutter.description}}",
  "author": "{{dkcutter.authorName}}",
  "license": "MIT",
  "scripts": {
    "dev": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next dev",
    "build": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next build",
    "start": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next start",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "db:generate": "dotenv -e .env -- prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env -- prisma migrate deploy",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "lint": "eslint .",
    "lint:fix": "{{ dkcutter._pkgRun }} lint {{ '-- ' if dkcutter.pkgManager == 'npm' }}--fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "{{ dkcutter._pkgRun }} lint && {{ dkcutter._pkgRun }} typecheck",
    "pre-commit": "{{ 'nano-staged' if dkcutter.useNanoStaged else 'lint-staged' }}",
    "commit-msg": "commitlint --edit",
    "prepare": "husky",
    "postinstall": "next typegen"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.23",
    "@clerk/nextjs": "7.5.19",
    "@hookform/resolvers": "5.4.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-query": "5.101.2",
    "@trigger.dev/sdk": "4.5.4",
    "@unpic/react": "1.0.2",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-intl": "4.13.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@ncontiero/eslint-config": "8.4.1",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@trigger.dev/build": "4.5.4",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "10.0.3",
    "dotenv-cli": "11.0.0",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "nano-staged": "1.0.2",
    "postcss": "8.5.19",
    "prisma": "7.8.0",
    "shadcn": "4.13.0",
    "tailwindcss": "4.3.2",
    "trigger.dev": "4.5.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "{{ 'nano-staged' if dkcutter.useNanoStaged else 'lint-staged' }}": {
    "*": "{{ dkcutter._pkgRun }} lint:fix"
  }
}
