{
  "name": "{{dkcutter.projectSlug}}",
  "type": "module",
  "version": "{{dkcutter.projectVersion}}",
  "private": true,
  "packageManager": "",
  "description": "{{dkcutter.description}}",
  "author": "{{dkcutter.authorName}}",
  "license": "MIT",
  "scripts": {
    "dev": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next dev",
    "build": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next build",
    "start": "{% if dkcutter.pkgManager == 'bun' %}bun --bun {% endif %}next start",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "db:generate": "dotenv -e .env -- prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "lint": "eslint .",
    "lint:fix": "{{ dkcutter._pkgRun }} lint {{ '-- ' if dkcutter.pkgManager == 'npm' }}--fix",
    "typecheck": "tsc --noEmit",
    "check": "{{ dkcutter._pkgRun }} lint && {{ dkcutter._pkgRun }} typecheck",
    "pre-commit": "{{ 'nano-staged' if dkcutter.useNanoStaged else 'lint-staged' }}",
    "commit-msg": "commitlint --edit",
    "prepare": "husky",
    "postinstall": "next typegen"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.20",
    "@clerk/nextjs": "^7.5.8",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "5.101.1",
    "@trigger.dev/sdk": "4.4.6",
    "better-auth": "1.6.20",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@ncontiero/eslint-config": "8.3.2",
    "@tailwindcss/postcss": "4.3.1",
    "@tanstack/eslint-plugin-query": "5.101.1",
    "@tanstack/react-query-devtools": "5.101.1",
    "@trigger.dev/build": "4.4.6",
    "@types/node": "^25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^10.0.3",
    "dotenv-cli": "11.0.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nano-staged": "1.0.2",
    "postcss": "^8.5.15",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.1",
    "trigger.dev": "4.4.6",
    "typescript": "^6.0.3"
  },
  "{{ 'nano-staged' if dkcutter.useNanoStaged else 'lint-staged' }}": {
    "*": "{{ dkcutter._pkgRun }} lint:fix"
  }
}
