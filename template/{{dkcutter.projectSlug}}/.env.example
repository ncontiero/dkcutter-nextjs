# When adding additional environment variables, the schema in "./src/env.js"
# should be updated accordingly.
{%- if dkcutter.useDockerCompose %}

# ------ POSTGRES ENV ------
# Postgres
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgresw"
{%- endif %}
{%- if dkcutter.usePrisma %}

# Database URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgresw@localhost:5432/postgres"
{%- endif %}
{%- if dkcutter.authProvider == "clerk" %}

# Clerk Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"
{%- if dkcutter.useClerkWebhook %}
CLERK_WEBHOOK_SIGNING_SECRET="YOUR_CLERK_WEBHOOK_SIGNING_SECRET"
{%- endif %}

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
{%- elif dkcutter.authProvider == "betterAuth" %}

# Better Auth
BETTER_AUTH_SECRET="!!!SET BETTER_AUTH_SECRET!!!"
BETTER_AUTH_URL="http://localhost:3000"
# Better Auth Google Provider
AUTH_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
AUTH_GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
{%- endif %}
